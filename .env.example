# Copy this file to .env on the homeserver and fill in real values before running:
#   docker compose -f docker-compose.prod.yml up -d --build

# Public URL the app is served at. Required so SvelteKit's CSRF protection accepts
# form submissions coming through the tunnel/domain instead of localhost.
ORIGIN=https://poker.yourdomain.com

# Token for the Cloudflare Tunnel (Zero Trust dashboard -> Networks -> Tunnels ->
# create a tunnel -> "Docker" connector method gives you this token).
# Set the tunnel's public hostname route to point at: http://poker-app:3000
CLOUDFLARE_TUNNEL_TOKEN=
