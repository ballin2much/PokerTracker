FROM node:26-alpine

WORKDIR /app

# Run as the image's built-in non-root "node" user (uid/gid 1000) instead of root.
# ./SK is bind-mounted from the host, so files this container writes (e.g. .svelte-kit/)
# would otherwise end up root-owned on the host and unwritable by the host user.
RUN chown node:node /app
USER node

COPY --chown=node:node package*.json ./
RUN npm install

COPY --chown=node:node . .

EXPOSE 5173

# Run the development server and bind it to all network interfaces
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]